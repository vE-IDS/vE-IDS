# Development image for the SPA: the Vite dev server with HMR. Source is
# bind-mounted by docker-compose. Production embeds the built SPA in the Go
# image instead (see api/Dockerfile) — there is no production frontend image.
FROM node:22-alpine
RUN corepack enable
WORKDIR /app
EXPOSE 3000
CMD ["sh", "-c", "pnpm install && pnpm dev --host"]
