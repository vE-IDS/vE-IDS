# vE-IDS API + docker-compose configuration.
#
# This file is consumed ONLY by the Go API and docker-compose (at runtime).
# It is NEVER bundled into the frontend — the SPA is same-origin and calls the
# API via relative /api paths, so it needs no secrets and no build-time config.
# Copy to `.env` and fill in the VATSIM values. NEVER commit the real `.env`.

# ----- Runtime -----
ENV=dev                        # dev | prod  (dev = text logs, non-Secure cookies)
PORT=8080
APP_BASE_URL=http://localhost:8080   # public origin (redirect URIs, cookie domain, WS origin check)

# ----- Database -----
# For local `go run`: point at your local Postgres.
# docker-compose overrides this to postgres://veids:veids@postgres:5432/veids.
DATABASE_URL=postgres://veids:veids@localhost:5432/veids?sslmode=disable

# ----- VATSIM Connect OAuth (register an app at https://auth-dev.vatsim.net) -----
VATSIM_AUTH_URL=https://auth-dev.vatsim.net   # prod: https://auth.vatsim.net
VATSIM_CLIENT_ID=
VATSIM_CLIENT_SECRET=
# Defaults to ${APP_BASE_URL}/api/auth/vatsim/callback when unset:
# VATSIM_REDIRECT_URI=http://localhost:8080/api/auth/vatsim/callback
VATSIM_SCOPES=full_name email vatsim_details country

# ----- JWT / sessions -----
JWT_SIGNING_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
# COOKIE_DOMAIN=            # optional explicit cookie domain (leave blank for host-only)

# ----- Upstream feeds (no API keys required) -----
DATAFEED_URL=https://data.vatsim.net/v3/vatsim-data.json
DATAFEED_POLL_INTERVAL=15s
METAR_URL=https://aviationweather.gov/api/data/metar
CHARTS_API_URL=https://api-v2.aviationapi.com/v2
CHARTS_CACHE_TTL=24h
